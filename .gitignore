# --- 자격증명·환경변수 ---
.env
.env.*
!.env.example
*.token
*.pat
*.key
*.pem

# --- Copilot CLI / hooks 로컬 산출물 ---
.copilot/
!.copilot/.gitkeep
.github/hooks/logs/
!.github/hooks/logs/.gitkeep

# --- 수집 산출물 (대용량) ---
보관함/다운로드/**
!보관함/다운로드/**/*.meta.json
!보관함/다운로드/**/README.md
!보관함/다운로드/.gitkeep
보관함/결과/**
!보관함/결과/.gitkeep
!보관함/결과/**/*.md
!보관함/결과/**/*.jsonl
# Nemotron-Personas-Korea: AGENTS.md 예외 규칙처럼 원본 식별용 서비스 경로는 영문 유지, parquet 원본은 커밋 금지
보관함/다운로드/huggingface.co/datasets/nvidia/Nemotron-Personas-Korea/**/*.parquet

# --- 외부 데이터 저장소 ---
data/legalize-kr/
data/precedent-kr/
data/admrule-kr/
data/ordinance-kr/

# --- Python (uv) ---
.venv/
__pycache__/
*.py[cod]
*.egg-info/
.pytest_cache/
.ruff_cache/
.mypy_cache/

# --- Node ---
node_modules/
dist/
build/
*.log
.npm/

# --- VS Code 사용자별 ---
.vscode/*.local.json

# --- OS ---
.DS_Store
Thumbs.db
desktop.ini

# --- 세션 로컬 상태 ---
.goals/

# --- 기타 임시 ---
*.tmp
*.bak
*~
