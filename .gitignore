# --- 자격증명·환경변수 ---
.env
.env.*
!.env.example
*.token
*.pat
*.key
*.pem

# --- Copilot CLI / hooks 로컬 산출물 ---
.copilot/
!.copilot/.gitkeep
.github/hooks/logs/
!.github/hooks/logs/.gitkeep

# --- 수집 산출물 (대용량) ---
archive/raw/**
!archive/raw/**/*.meta.json
!archive/raw/**/README.md
!archive/raw/.gitkeep
archive/processed/**
!archive/processed/.gitkeep
!archive/processed/**/*.md
!archive/processed/**/*.jsonl
# Nemotron-Personas-Korea: parquet 원본은 절대 커밋하지 않음 (CC BY 4.0, 약 2GB)
archive/raw/huggingface.co/datasets/nvidia/Nemotron-Personas-Korea/**/*.parquet

# --- Python (uv) ---
.venv/
__pycache__/
*.py[cod]
*.egg-info/
.pytest_cache/
.ruff_cache/
.mypy_cache/

# --- Node ---
node_modules/
dist/
build/
*.log
.npm/

# --- VS Code 사용자별 ---
.vscode/*.local.json

# --- OS ---
.DS_Store
Thumbs.db
desktop.ini

# --- 기타 임시 ---
*.tmp
*.bak
*~
