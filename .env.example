# 이 파일은 키 이름만 보여주는 템플릿입니다. 실제 값은 `.env`에 채우고
# `.env`는 절대 커밋하지 마세요. (.gitignore가 이미 차단)

# --- GitHub ---
# 보통 `gh auth login`으로 처리. 직접 토큰을 써야 할 때만 채웁니다.
# GH_TOKEN=

# --- Google NotebookLM (PleasePrompto/notebooklm-mcp 사용 시) ---
# NOTEBOOKLM_SESSION=

# --- 모델 BYOK (선택) ---
# OPENAI_API_KEY=
# ANTHROPIC_API_KEY=

# --- 어댑터별 ---
# OPEN_ASSEMBLY_API_KEY=
# DATA_GO_KR_API_KEY=
