# 기본 — 한글 파일/문서 안전한 UTF-8 처리
* text=auto eol=lf

# Windows 전용 스크립트는 CRLF 유지
*.ps1   text eol=crlf
*.cmd   text eol=crlf
*.bat   text eol=crlf

# Bash/POSIX 스크립트는 항상 LF
*.sh    text eol=lf

# 바이너리
*.png   binary
*.jpg   binary
*.pdf   binary
*.hwp   binary
*.hwpx  binary
*.zip   binary

# 한국어 검색 가능하도록 diff 드라이버 힌트
*.md    diff=markdown
