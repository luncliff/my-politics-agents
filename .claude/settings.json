{
  "env": {
    "CLAUDE_CODE_USE_BEDROCK": "1",
    "CLAUDE_CODE_EXPERIMENTAL_AGENT_TEAMS": "1",
    "CLAUDE_CODE_DISABLE_NONESSENTIAL_TRAFFIC": "1",
    "API_TIMEOUT_MS": "600000"
  },
  "autoUpdatesChannel": "latest",
  "enabledPlugins": {
    "mcp-server-dev@claude-plugins-official": true
  },
  "teammateMode": "in-process",
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "pwsh",
            "args": ["-NoProfile", "-ExecutionPolicy", "Bypass", "-File", "scripts/session-start.ps1"],
            "shell": "powershell"
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "pwsh",
            "args": ["-NoProfile", "-ExecutionPolicy", "Bypass", "-File", "scripts/session-stop.ps1"],
            "shell": "powershell"
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "pwsh",
            "args": ["-NoProfile", "-ExecutionPolicy", "Bypass", "-File", "scripts/pre-tool-bash.ps1"],
            "shell": "powershell"
          }
        ]
      }
    ]
  }
}
