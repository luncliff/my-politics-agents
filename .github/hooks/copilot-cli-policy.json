{
  "$schema": "https://aka.ms/copilot-cli-hooks-schema",
  "version": 1,
  "description": "my-politics-agents — logging-first Copilot CLI policy. 한 개의 deny 데모만 활성.",
  "hooks": {
    "sessionStart": [
      {
        "name": "policy-banner",
        "command": {
          "windows": "pwsh -NoProfile -ExecutionPolicy Bypass -File .github/hooks/scripts/session-banner.ps1",
          "default": "bash .github/hooks/scripts/session-banner.sh"
        }
      }
    ],
    "userPromptSubmitted": [
      {
        "name": "log-prompt",
        "command": {
          "windows": "pwsh -NoProfile -ExecutionPolicy Bypass -File .github/hooks/scripts/log-prompt.ps1",
          "default": "bash .github/hooks/scripts/log-prompt.sh"
        }
      }
    ],
    "preToolUse": [
      {
        "name": "pre-tool-policy",
        "command": {
          "windows": "pwsh -NoProfile -ExecutionPolicy Bypass -File .github/hooks/scripts/pre-tool-policy.ps1",
          "default": "bash .github/hooks/scripts/pre-tool-policy.sh"
        }
      }
    ]
  }
}
