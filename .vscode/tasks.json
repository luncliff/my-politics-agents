    {
      "label": "civic: copilot session continue",
      "type": "shell",
      "command": "copilot",
      "args": [
        "--continue"
      ],
      "presentation": {
        "reveal": "always",
        "panel": "dedicated"
      },
      "problemMatcher": []
    },
    {
      "label": "civic: search night care",
      "type": "shell",
      "command": "copilot",
      "args": [
        "--model=auto",
        "--allow-all-urls",
        "--add-dir",
        "${workspaceFolder}",
        "--prompt",
        "/search-night-care with current location.txt"
      ]
    },
    {
      "label": "civic: notebooklm login",
      "type": "shell",
