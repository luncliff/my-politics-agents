        "command": "pwsh",
        "args": [
          "-NoProfile",
          "-Command",
          "uvx --from notebooklm-mcp-cli nlm login"
        ]
      },
      "linux": {
        "command": "bash",
        "args": [
          "-lc",
          "uvx --from notebooklm-mcp-cli nlm login"
        ]
