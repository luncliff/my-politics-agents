{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "civic: setup",
      "type": "shell",
      "command": "${command:workbench.action.terminal.sendSequence}",
      "windows": {
        "command": "pwsh",
        "args": [
          "-NoProfile",
          "-ExecutionPolicy",
          "Bypass",
          "-File",
          "scripts/setup.ps1"
        ]
      },
      "linux": {
        "command": "bash",
        "args": [
          "scripts/setup.sh"
        ]
      },
      "osx": {
        "command": "zsh",
        "args": [
          "scripts/setup.sh"
        ]
      },
      "problemMatcher": []
    },
    {
      "label": "civic: fetch legalize-kr repos (shallow clone)",
      "type": "shell",
      "windows": {
        "command": "pwsh",
        "args": [
          "-NoProfile",
          "-ExecutionPolicy",
          "Bypass",
          "-File",
          "scripts/fetch_legalize_kr.ps1"
        ]
      },
      "linux": {
        "command": "bash",
        "args": [
          "scripts/fetch_legalize_kr.sh"
        ]
      },
      "osx": {
        "command": "bash",
        "args": [
          "scripts/fetch_legalize_kr.sh"
        ]
      },
      "problemMatcher": []
    },
