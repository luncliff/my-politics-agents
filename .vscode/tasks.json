    {
      "label": "civic: lint js/ts",
      "type": "shell",
      "command": "npm",
      "args": ["run", "lint"],
      "problemMatcher": ["$eslint-stylish"],
      "group": "test",
      "presentation": {
        "reveal": "always",
        "panel": "shared"
      }
    },
    {
      "label": "civic: format js/ts",
      "type": "shell",
      "command": "npm",
      "args": ["run", "format"],
      "problemMatcher": [],
      "presentation": {
        "reveal": "always",
        "panel": "shared"
      }
    },
    {
      "label": "civic: lint prompts/skills",
      "type": "shell",
      "windows": {
        "command": "pwsh",
        "args": [
          "-NoProfile",
          "-Command",
          "python scripts/lint_frontmatter.py"
        ]
      },
      "linux": {
        "command": "bash",
        "args": [
