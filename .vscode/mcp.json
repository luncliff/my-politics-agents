{
  "$schema": "https://aka.ms/vscode-mcp-servers-schema",
  "servers": {
    "notebooklm": {
      "type": "stdio",
      "command": "uvx",
      "args": [
        "--from",
        "notebooklm-mcp-cli",
        "notebooklm-mcp"
      ]
    },
    "legalize-kr": {
      "type": "stdio",
      "command": "uvx",
      "args": [
        "--from",
        "legalize-cli[mcp]",
        "legalize-mcp"
      ],
      "env": {
        "GITHUB_TOKEN": "${env:GITHUB_TOKEN}"
      }
    }
  }
}