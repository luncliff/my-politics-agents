{
  "$schema": "https://aka.ms/vscode-mcp-servers-schema",
  "servers": {
    "notebooklm": {
      "command": "npx",
      "args": [
        "notebooklm-mcp@latest"
      ]
    },
    "gov-archive": {
      "type": "stdio",
      "command": "uv",
      "args": [
        "run",
        "--directory",
        "mcp-servers/gov-archive",
        "gov-archive"
      ],
      "dev": {
        "watch": [
          "mcp-servers/gov-archive/src/**/*.py"
        ],
        "debug": {
          "type": "python"
        }
      }
    },
    "legalize-kr": {
      "type": "stdio",
      "command": "uvx",
      "args": [
        "--from",
        "legalize-cli[mcp]",
        "legalize-mcp"
      ],
      "env": {
        "GITHUB_TOKEN": "${env:GITHUB_TOKEN}"
      }
    }
  }
}